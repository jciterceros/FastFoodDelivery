// ====================================================================
// TABELAS
// ====================================================================

// ====================================================================
// Dominio 00: Plataforma Transversal
// ====================================================================

Table infra_service_registry {
    id uuid  [pk, default: `uuid_generate_v4()`]
    service_name varchar(64)  [not null]
    base_url varchar(256)  [not null]
    health_endpoint varchar(128)  [not null, default: `'/HEALTH'`]
    health_status varchar(16)  [not null, default: `'HEALTHY'`]
    last_health_check timestamp 
    schema_version varchar(16) 
    created_at timestamp  [not null, default: `NOW()`]
    updated_at timestamp  [not null, default: `NOW()`]
    note: 'unique(service_name)'
}

Table infra_rate_limit_rules {
    id uuid  [pk, default: `uuid_generate_v4()`]
    route_pattern varchar(256)  [not null]
    limit_per_second integer  [not null]
    limit_per_minute integer  [not null]
    limit_per_hour integer  [not null]
    scope varchar(32)  [not null]
    created_at timestamp  [not null, default: `NOW()`]
    updated_at timestamp  [not null, default: `NOW()`]
}

Table infra_dead_letter_log {
    id uuid  [pk, default: `uuid_generate_v4()`]
    event_id uuid  [not null]
    event_type varchar(64)  [not null]
    source_service varchar(64)  [not null]
    error_message text 
    error_code varchar(32) 
    retry_count integer  [not null, default: `0`]
    payload jsonb 
    failed_at timestamp  [not null, default: `NOW()`]
    reprocessed_at timestamp 
    status varchar(16)  [not null, default: `'PENDING'`]
}

// ====================================================================
// Dominio 01: Identidade e Usuarios
// ====================================================================

// --- schema: auth ---

Table auth_users {
    id uuid  [pk, default: `uuid_generate_v4()`]
    email varchar(255)  [not null]
    email_verified_at timestamp 
    phone varchar(32) 
    phone_verified_at timestamp 
    password_hash varchar(255)  [not null]
    status varchar(32)  [not null, default: `'ACTIVE'`]
    created_at timestamp  [not null, default: `NOW()`]
    updated_at timestamp  [not null, default: `NOW()`]
    note: 'unique(email)'
}

// --- schema: user ---

// user_user_profiles — Dados do perfil do usuário
Table user_user_profiles {
    user_id uuid  [pk]
    full_name varchar(255) 
    birth_date date 
    marketing_opt_in boolean  [not null, default: `false`]
    preferred_language varchar(10)  [not null, default: `'PT-BR'`]
    updated_at timestamp  [not null, default: `NOW()`]
}

// user_user_addresses — Endereços do usuário
Table user_user_addresses {
    id uuid  [pk, default: `uuid_generate_v4()`]
    user_id uuid  [not null]
    label varchar(64) 
    zip_code varchar(16) 
    street varchar(255) 
    number varchar(16) 
    complement varchar(255) 
    neighborhood varchar(128) 
    city varchar(128) 
    state varchar(64) 
    country varchar(64)  [not null, default: `'BRASIL'`]
    latitude decimal(10,7) 
    longitude decimal(10,7) 
    is_default boolean  [not null, default: `false`]
    created_at timestamp  [not null, default: `NOW()`]
    updated_at timestamp  [not null, default: `NOW()`]
}

// user_user_consents — Registro de consentimento LGPD
Table user_user_consents {
    id uuid  [pk, default: `uuid_generate_v4()`]
    user_id uuid  [not null]
    consent_type varchar(64)  [not null]
    version varchar(16)  [not null]
    accepted_at timestamp  [not null, default: `NOW()`]
    source varchar(64) 
}

// user_refresh_tokens — Tokens de refresh rotativos
Table user_refresh_tokens {
    id uuid  [pk, default: `uuid_generate_v4()`]
    user_id uuid  [not null]
    token_hash varchar(255)  [not null]
    device_id varchar(128) 
    expires_at timestamp  [not null]
    revoked_at timestamp 
    created_at timestamp  [not null, default: `NOW()`]
}

// user_user_devices — Dispositivos do usuário
Table user_user_devices {
    id uuid  [pk, default: `uuid_generate_v4()`]
    user_id uuid  [not null]
    device_id varchar(255)  [not null]
    platform varchar(32) 
    push_token varchar(512) 
    last_seen_at timestamp 
    created_at timestamp  [not null, default: `NOW()`]
    note: 'unique(device_id)'
}

