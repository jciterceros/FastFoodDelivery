Table realtime_tracking_sessions {
    id uuid  [pk, default: `uuid_generate_v4()`]
    order_id uuid  [not null]
    user_id uuid  [not null]
    device_id varchar(255) 
    session_token varchar(255)  [not null]
    status varchar(32)  [not null, default: `'CONNECTED'`]
    connected_at timestamp  [not null, default: `NOW()`]
    disconnected_at timestamp 
    last_activity_at timestamp 
    messages_sent integer  [not null, default: `0`]
    ip_address varchar(45) 
    user_agent varchar(512) 
    note: 'unique(session_token)'
}

Table realtime_tracking_snapshots {
    id uuid  [pk, default: `uuid_generate_v4()`]
    order_id uuid  [not null]
    courier_lat decimal(10,7) 
    courier_lon decimal(10,7) 
    courier_geohash varchar(12) 
    milestone varchar(32) 
    milestone_changed_at timestamp 
    estimated_eta timestamp 
    pickup_lat decimal(10,7) 
    pickup_lon decimal(10,7) 
    dropoff_lat decimal(10,7) 
    dropoff_lon decimal(10,7) 
    polyline_encoded text 
    version integer  [not null, default: `1`]
    updated_at timestamp  [not null, default: `NOW()`]
    note: 'unique(order_id)'
}

