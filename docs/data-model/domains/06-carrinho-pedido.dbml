// Schema(s): order
// Gerado automaticamente de V1__Initial_Schema.sql
// ====================================================================

// order_orders — Pedido confirmado — agregado central do fluxo transacional
Table order_orders {
    id uuid  [pk, default: `uuid_generate_v4()`]
    user_id uuid  [not null]
    restaurant_id uuid  [not null]
    status varchar(32)  [not null, default: `'PENDING'`]
    subtotal_cents integer  [not null, default: `0`]
    delivery_fee_cents integer  [not null, default: `0`]
    discount_cents integer  [not null, default: `0`]
    total_cents integer  [not null, default: `0`]
    promotion_code varchar(64) 
    delivery_latitude decimal(10,7) 
    delivery_longitude decimal(10,7) 
    delivery_address_snapshot jsonb 
    estimated_minutes integer 
    idempotency_key varchar(255)  [not null]
    created_at timestamp  [not null, default: `NOW()`]
    updated_at timestamp  [not null, default: `NOW()`]
    note: 'unique(idempotency_key)'
}

// order_order_items — Itens do pedido (snapshot de preços)
Table order_order_items {
    id uuid  [pk, default: `uuid_generate_v4()`]
    order_id uuid  [not null]
    item_id uuid  [not null]
    name varchar(255)  [not null]
    quantity integer  [not null]
    unit_price_cents integer  [not null]
    modifiers_snapshot jsonb 
    total_price_cents integer  [not null]
    notes varchar(512) 
}

// order_inventory_reservations — Reserva de estoque no checkout
Table order_inventory_reservations {
    id uuid  [pk, default: `uuid_generate_v4()`]
    item_id uuid  [not null]
    order_id uuid  [not null]
    quantity integer  [not null]
    status varchar(32)  [not null, default: `'RESERVED'`]
    expires_at timestamp  [not null]
    created_at timestamp  [not null, default: `NOW()`]
}

// ── Intra-domain Relationships ──

Ref: order_inventory_reservations.order_id > order_orders.id
Ref: order_order_items.order_id > order_orders.id

