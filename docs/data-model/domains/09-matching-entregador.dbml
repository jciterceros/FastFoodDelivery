Table dispatch_delivery_offers {
    id uuid  [pk, default: `uuid_generate_v4()`]
    order_id uuid  [not null]
    courier_id uuid  [not null]
    attempt smallint  [not null, default: `1`]
    status varchar(32)  [not null, default: `'PENDING'`]
    expires_at timestamp  [not null]
    responded_at timestamp 
    rejection_reason varchar(64) 
    created_at timestamp  [not null, default: `NOW()`]
}

Table dispatch_delivery_assignments {
    id uuid  [pk, default: `uuid_generate_v4()`]
    order_id uuid  [not null]
    courier_id uuid  [not null]
    offer_id uuid 
    status varchar(32)  [not null, default: `'ASSIGNED'`]
    assigned_at timestamp  [not null, default: `NOW()`]
    picked_up_at timestamp 
    completed_at timestamp 
    cancelled_at timestamp 
    cancellation_reason varchar(255) 
    note: 'unique(order_id)'
}

Table dispatch_courier_sessions {
    id uuid  [pk, default: `uuid_generate_v4()`]
    courier_id uuid  [not null]
    is_online boolean  [not null, default: `false`]
    current_geohash varchar(12) 
    last_lat decimal(10,7) 
    last_lon decimal(10,7) 
    status varchar(32)  [not null, default: `'OFFLINE'`]
    current_delivery_id uuid 
    battery_level smallint 
    created_at timestamp  [not null, default: `NOW()`]
    updated_at timestamp  [not null, default: `NOW()`]
    note: 'unique(courier_id)'
}

Table dispatch_escalation_queue {
    id uuid  [pk, default: `uuid_generate_v4()`]
    order_id uuid  [not null]
    attempts smallint  [not null, default: `0`]
    last_attempt_at timestamp 
    escalated_at timestamp  [not null, default: `NOW()`]
    status varchar(32)  [not null, default: `'PENDING'`]
    resolved_by uuid 
    resolved_at timestamp 
    notes text 
    note: 'unique(order_id)'
}

Table dispatch_courier_availability_history {
    id uuid  [pk, default: `uuid_generate_v4()`]
    courier_id uuid  [not null]
    previous_status varchar(32) 
    new_status varchar(32)  [not null]
    reason varchar(255) 
    geohash varchar(12) 
    created_at timestamp  [not null, default: `NOW()`]
}

